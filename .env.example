# =========================================================================
# Configuration Zoho CRM — Formation Compétences
# =========================================================================
# Copier ce fichier en .env (qui est gitignored) et remplir les valeurs.
# Le serveur lit .env automatiquement au démarrage (dotenv).

# Mode de fonctionnement de l'intégration Zoho :
#   - dry_run  : aucun appel à Zoho. Les leads sont seulement loggés. (DÉFAUT)
#   - shadow   : créer le Contact dans Zoho mais SANS déclencher de workflow,
#                blueprint, approval ni orchestration (trigger:[]).
#                À utiliser pour la validation par le référent technique.
#   - live     : production normale, triggers actifs.
ZOHO_MODE=dry_run

# Credentials OAuth (générés via https://api-console.zoho.com/)
# Voir docs/ZOHO-SETUP.md pour la procédure pas-à-pas.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Domaines Zoho selon votre data center :
#   - Europe (.eu)  → ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.eu
#                     ZOHO_API_DOMAIN=https://www.zohoapis.eu
#   - États-Unis (.com) → ...zoho.com / ...zohoapis.com
#   - Inde (.in), Australie (.com.au), Chine (.com.cn), Japon (.jp), etc.
ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.eu
ZOHO_API_DOMAIN=https://www.zohoapis.eu

# Limite de requêtes par IP par minute pour /api/leads
LEAD_RATE_LIMIT_PER_MIN=5

# Port du serveur Express
PORT=8080
